AUTHORIZED_KEYS_PATH = ENV.fetch(
  "AUTHORIZED_KEYS_PATH",
  File.expand_path("../.authorized_keys", __dir__)
)

AUTHORIZED_KEYS = File.exist?(AUTHORIZED_KEYS_PATH) ? File.read(AUTHORIZED_KEYS_PATH).strip : ""

raise "authorized_keys not found or empty: #{AUTHORIZED_KEYS_PATH}" if AUTHORIZED_KEYS.empty?

Vagrant.configure("2") do |config|
  config.vm.box = "generic/oracle8"
  config.vm.synced_folder ".", "/vagrant", disabled: true
  config.ssh.insert_key = false

  nodes = [
    { name: "weblogic", hostname: "weblogic.local", ip: "192.168.200.200", mem: 4096, cpu: 4, ports: [7001, 7002] },
    { name: "database", hostname: "database.local", ip: "192.168.200.201", mem: 2048, cpu: 2, ports: [1521] }
  ]

  nodes.each do |node|
    config.vm.define node[:name] do |vm|
      vm.vm.hostname = node[:hostname]

      vm.vm.network "public_network",
        ip: node[:ip]

      vm.vm.provider "virtualbox" do |vb|
        vb.name = "#{node[:name]}-vm"
        vb.memory = node[:mem]
        vb.cpus = node[:cpu]
      end

      vm.vm.provision "shell", privileged: true, inline: <<-SHELL
        set -e

        dnf install -y python3.11 python3.11-pip python3-dnf python3-pexpect

        USER=vagrant
        HOME_DIR=/home/$USER
        SSH_DIR=$HOME_DIR/.ssh
        AUTH_KEYS=$SSH_DIR/authorized_keys

        mkdir -p "$SSH_DIR"
        chmod 700 "$SSH_DIR"
        touch "$AUTH_KEYS"
        chmod 600 "$AUTH_KEYS"
        chown -R "$USER:$USER" "$SSH_DIR"

        AUTHORIZED_KEYS_CONTENT='#{AUTHORIZED_KEYS.gsub("'", %q('"'"'))}'

        echo "$AUTHORIZED_KEYS_CONTENT" > "$AUTH_KEYS"
        chmod 600 "$AUTH_KEYS"
        chown "$USER:$USER" "$AUTH_KEYS"
      SHELL
    end
  end
end